FROM python:3.12-slim

# 时区（日志、Python datetime；运行时可 -e TZ=... 覆盖）
ARG TZ=Asia/Shanghai
ENV TZ=${TZ}
RUN apt-get update && apt-get install -y --no-install-recommends tzdata \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
# 默认配置：启动时可用 -e 覆盖，未覆盖则使用此 .env
COPY .env.example .env

WORKDIR /app
RUN uv sync --frozen 2>/dev/null || uv sync

EXPOSE 8000
# 禁用 Python 输出缓冲，确保日志即时输出到 docker logs
ENV PYTHONUNBUFFERED=1
# --log-level info：输出请求日志；--access-log：记录每次 HTTP 请求
CMD ["uv", "run", "uvicorn", "agentarena.main:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info", "--access-log"]
