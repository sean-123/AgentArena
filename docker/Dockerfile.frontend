FROM node:20-alpine

ARG TZ=Asia/Shanghai
ENV TZ=${TZ}
# dl-cdn 在部分网络环境下 TLS 失败会导致 apk 拉不到索引、tzdata 报 “no such package”
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories \
    && apk add --no-cache tzdata

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

EXPOSE 3000
# NEXT_PUBLIC_API_URL 供 Next.js rewrites 代理使用，启动时通过 -e 传入
CMD ["npm", "start"]
