# 容器/进程时区（Docker 与本地均可；影响日志与未指定 UTC 的时间显示）
TZ=Asia/Shanghai

# Nacos 配置中心（可选）
# 若配置 NACOS_SERVER_ADDR，则从 Nacos 拉取配置，覆盖 .env 中的对应项
# NACOS_SERVER_ADDR=localhost:8848
# NACOS_DATA_ID=agentarena
# NACOS_GROUP=DEFAULT_GROUP
# NACOS_NAMESPACE_ID=
# NACOS_USERNAME=
# NACOS_PASSWORD=
# NACOS_TIMEOUT=5

# Database (MySQL)
AGENTARENA_DB_HOST=localhost
AGENTARENA_DB_PORT=3306
AGENTARENA_DB_USER=root
AGENTARENA_DB_PASSWORD=
AGENTARENA_DB_NAME=agent_arena

# Redis
AGENTARENA_REDIS_HOST=localhost
AGENTARENA_REDIS_PORT=6379
AGENTARENA_REDIS_PASSWORD=
AGENTARENA_REDIS_DB=0

# API
AGENTARENA_API_HOST=0.0.0.0
AGENTARENA_API_PORT=8000

# LLM Judge (OpenAI / 兼容接口)
AGENTARENA_OPENAI_API_KEY=sk-...
# AGENTARENA_OPENAI_BASE_URL=https://api.openai.com/v1
# 使用阿里云 DashScope 示例：
# AGENTARENA_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/
AGENTARENA_LLM_MODEL=gpt-4o-mini

# Agent Bearer Token（在 Agent config_json 中 auth_token_env 引用）
# 例如 TWServiceGuide 的 auth_token_env: AGENT_TW_SERVICE_TOKEN
AGENT_TW_SERVICE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 对比通用大模型（DouBao/Qwen/DeepSeek）- 均使用 OpenAI SDK 调用
# 豆包（火山方舟）https://www.volcengine.com/docs/82379/1494384
AGENTARENA_DOUBAO_API_KEY=
AGENTARENA_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AGENTARENA_DOUBAO_MODEL=   # 火山方舟推理接入点 ID，如 ep-xxx
# 通义千问（阿里云）
AGENTARENA_QWEN_API_KEY=
AGENTARENA_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENTARENA_QWEN_MODEL=qwen-turbo
# DeepSeek
AGENTARENA_DEEPSEEK_API_KEY=
AGENTARENA_DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENTARENA_DEEPSEEK_MODEL=deepseek-chat

# Langfuse（全局配置，用于总结报告中读取 Agent 关联的 Prompt 并给出优化建议）
# host、public_key、secret_key 在此或 Nacos 中配置，Agent 配置中仅填 environment、prompt_ids
# 若使用 Nacos，在 dataId 对应的配置中添加：AGENTARENA_LANGFUSE_HOST、AGENTARENA_LANGFUSE_PUBLIC_KEY、AGENTARENA_LANGFUSE_SECRET_KEY
# AGENTARENA_LANGFUSE_HOST=https://cloud.langfuse.com
# AGENTARENA_LANGFUSE_PUBLIC_KEY=pk-lf-...
# AGENTARENA_LANGFUSE_SECRET_KEY=sk-lf-...
